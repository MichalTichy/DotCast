@page "/"
@inherits AppPage

@{
    var featured = FeaturedAudioBook;
    var authorGroups = Data
        .GroupBy(book => string.IsNullOrWhiteSpace(book.AudioBookInfo.AuthorName) ? "Unknown author" : book.AudioBookInfo.AuthorName)
        .OrderBy(group => group.Key)
        .ToList();
}

<section class="library-page">
    <header class="library-topbar">
        <div>
            <h1>Your library</h1>
        </div>
        <Field Class="library-search">
            <TextEdit Placeholder="Search titles, authors, series" Text="@SearchText" TextChanged="SearchTextChanged" />
        </Field>
    </header>

    <div class="library-layout">
        <aside class="library-filters" aria-label="Library filters">
            <div class="filter-header">
                <h2>Filters</h2>
                @if (HasActiveFilters)
                {
                    <button type="button" class="text-button" @onclick="ClearFilters">Clear</button>
                }
            </div>

            <details class="filter-collapse">
                <summary>
                    <span>Rating</span>
                    @if (MinRating is not null || MaxRating is not null)
                    {
                        <small>Active</small>
                    }
                </summary>
                <div class="filter-section">
                    <button type="button" class="filter-pill @(MinRating == 80 ? "is-active" : "")" @onclick="() => SetRatingRange(80, null)">80%+</button>
                    <button type="button" class="filter-pill @(MinRating == 60 && MaxRating == 79 ? "is-active" : "")" @onclick="() => SetRatingRange(60, 79)">60-79%</button>
                    <button type="button" class="filter-pill @(MaxRating == 59 ? "is-active" : "")" @onclick="() => SetRatingRange(null, 59)">Below 60%</button>
                </div>
            </details>

            <details class="filter-collapse">
                <summary>
                    <span>Authors</span>
                    @if (SelectedAuthors.Count > 0)
                    {
                        <small>@SelectedAuthors.Count</small>
                    }
                </summary>
                <div class="filter-section">
                    <TextEdit Class="filter-search" Placeholder="Search authors" @bind-Text="@AuthorFacetSearchText" />
                    @foreach (var author in FilteredAuthors)
                    {
                        <button type="button" class="filter-choice @(SelectedAuthors.Contains(author) ? "is-active" : "")" @onclick="() => ToggleAuthor(author)">
                            @author
                        </button>
                    }
                </div>
            </details>

            <details class="filter-collapse">
                <summary>
                    <span>Categories</span>
                    @if (SelectedCategories.Count > 0)
                    {
                        <small>@SelectedCategories.Count</small>
                    }
                </summary>
                <div class="filter-section">
                    <TextEdit Class="filter-search" Placeholder="Search categories" @bind-Text="@CategoryFacetSearchText" />
                    @foreach (var category in FilteredCategories)
                    {
                        <button type="button" class="filter-choice @(SelectedCategories.Contains(category) ? "is-active" : "")" @onclick="() => ToggleCategory(category)">
                            @category
                        </button>
                    }
                </div>
            </details>
        </aside>

        <main class="library-content">
            @if (featured is not null)
            {
                <section class="featured-strip">
                    <button type="button" class="featured-poster" @onclick="() => ShowDetails(featured)">
                        @if (!string.IsNullOrWhiteSpace(featured.AudioBookInfo.ImageUrl))
                        {
                            <img src="@featured.AudioBookInfo.ImageUrl" alt="@featured.AudioBookInfo.Name cover" />
                        }
                        else
                        {
                            <span>@featured.AudioBookInfo.Name</span>
                        }
                    </button>
                    <div class="featured-copy">
                        <p class="cinema-eyebrow">Featured audiobook</p>
                        <h2>@featured.AudioBookInfo.Name</h2>
                        <p>@featured.AudioBookInfo.AuthorName</p>
                        <div class="media-meta-row">
                            <span>@featured.Rating %</span>
                            <span>@($"{featured.AudioBookInfo.Duration.TotalHours:F0}:{featured.AudioBookInfo.Duration.Minutes:D2}")</span>
                            @if (!string.IsNullOrWhiteSpace(featured.AudioBookInfo.SeriesName))
                            {
                                <span>@featured.AudioBookInfo.SeriesName @featured.AudioBookInfo.OrderInSeries</span>
                            }
                        </div>
                    </div>
                </section>
            }

            <section class="library-stats">
                <article><strong>@AudioBooksStatistics.TotalCount</strong><span>Titles</span></article>
                <article><strong>@AudioBooksStatistics.AuthorCount</strong><span>Authors</span></article>
                <article><strong>@($"{AudioBooksStatistics.TotalDuration.TotalHours:F0}h")</strong><span>Total listening</span></article>
            </section>

            @if (IsLoading)
            {
                <div class="library-state">Loading audiobooks...</div>
            }
            else if (Data.Count == 0)
            {
                <div class="library-state">
                    <h2>No audiobooks found</h2>
                    <p>Adjust filters or clear the current search.</p>
                    @if (HasActiveFilters)
                    {
                        <button type="button" class="primary-action" @onclick="ClearFilters">Clear filters</button>
                    }
                </div>
            }
            else
            {
                @foreach (var author in authorGroups)
                {
                    <section class="media-rail">
                        <div class="rail-heading">
                            <h2>@author.Key</h2>
                            <span>@author.Count() title(s)</span>
                        </div>

                        @foreach (var series in author
                            .GroupBy(book => string.IsNullOrWhiteSpace(book.AudioBookInfo.SeriesName) ? StandaloneSeriesName : book.AudioBookInfo.SeriesName)
                            .OrderBy(group => group.Key == StandaloneSeriesName ? 1 : 0)
                            .ThenBy(group => group.Key))
                        {
                            <div class="series-section @(series.Key == StandaloneSeriesName ? "series-section-standalone" : "")">
                                @if (series.Key != StandaloneSeriesName)
                                {
                                    <div class="series-splitter">
                                        <span>@series.Key</span>
                                    </div>
                                }

                                <div class="poster-row">
                                    @foreach (var audioBook in series.OrderBy(book => book.AudioBookInfo.OrderInSeries).ThenBy(book => book.AudioBookInfo.Name))
                                    {
                                        <article class="poster-card">
                                            <button type="button" class="poster-button" @onclick="() => ShowDetails(audioBook)">
                                                @if (!string.IsNullOrWhiteSpace(audioBook.AudioBookInfo.ImageUrl))
                                                {
                                                    <img src="@audioBook.AudioBookInfo.ImageUrl" alt="@audioBook.AudioBookInfo.Name cover" />
                                                }
                                                else
                                                {
                                                    <span>@audioBook.AudioBookInfo.Name</span>
                                                }
                                            </button>
                                            <div class="poster-info">
                                                <h3>@audioBook.AudioBookInfo.Name</h3>
                                                <p>@audioBook.Rating % - @($"{audioBook.AudioBookInfo.Duration.TotalHours:F0}:{audioBook.AudioBookInfo.Duration.Minutes:D2}")</p>
                                                @if (audioBook.AudioBookInfo.Categories.Count > 0)
                                                {
                                                    <div class="poster-tags" aria-label="@($"{audioBook.AudioBookInfo.Name} categories")">
                                                        @foreach (var category in audioBook.AudioBookInfo.Categories)
                                                        {
                                                            <span>@category.Name</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </article>
                                    }
                                </div>
                            </div>
                        }
                    </section>
                }

            }
        </main>
    </div>
</section>

@if (SelectedAudioBook is not null)
{
    <div class="quick-drawer-backdrop" @onclick="CloseDetails"></div>
    <aside class="quick-drawer" role="dialog" aria-modal="true" aria-label="Audiobook details">
        <button type="button" class="drawer-close" @onclick="CloseDetails">Close</button>
        <div class="drawer-hero">
            @if (!string.IsNullOrWhiteSpace(SelectedAudioBook.AudioBookInfo.ImageUrl))
            {
                <img src="@SelectedAudioBook.AudioBookInfo.ImageUrl" alt="@SelectedAudioBook.AudioBookInfo.Name cover" />
            }
            <div>
                <p class="cinema-eyebrow">Audiobook</p>
                <h2>@SelectedAudioBook.AudioBookInfo.Name</h2>
                <p>@SelectedAudioBook.AudioBookInfo.AuthorName</p>
                <div class="media-meta-row">
                    <span>@SelectedAudioBook.Rating %</span>
                    <span>@($"{SelectedAudioBook.AudioBookInfo.Duration.TotalHours:F0}:{SelectedAudioBook.AudioBookInfo.Duration.Minutes:D2}")</span>
                    @if (!string.IsNullOrWhiteSpace(SelectedAudioBook.AudioBookInfo.SeriesName))
                    {
                        <span>@SelectedAudioBook.AudioBookInfo.SeriesName @SelectedAudioBook.AudioBookInfo.OrderInSeries</span>
                    }
                </div>
            </div>
        </div>

        <div class="drawer-tags">
            @foreach (var category in SelectedAudioBook.AudioBookInfo.Categories)
            {
                <span>@category.Name</span>
            }
        </div>

        <p class="drawer-description">@SelectedAudioBook.AudioBookInfo.Description</p>

        <div class="drawer-actions">
            <Button Color="Color.Primary" Clicked="async () => await CopyRssAsync(SelectedAudioBook)">Copy RSS</Button>
            @if (!string.IsNullOrWhiteSpace(SelectedAudioBook.AudioBookInfo.ArchiveUrl))
            {
                <Button Color="Color.Secondary" Clicked="async () => await Download(SelectedAudioBook)">Download</Button>
            }
            <a class="secondary-action" href="@($"AudioBook/{SelectedAudioBook.Id}/edit")">Edit</a>
        </div>
    </aside>
}

<script>
    function copyToClipboard(link) {
        navigator.clipboard.writeText(link).then(() => {
            alert("Link copied to clipboard!");
        }).catch(err => {
            window.open(link,'_blank');
            console.error("Failed to copy link: ", err);
        });
    }
</script>
