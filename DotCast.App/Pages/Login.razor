@page "/Login"
@page "/Login/{Message}"
@using DotCast.App.API
@using Microsoft.AspNetCore.WebUtilities

@inject IJSRuntime js
@inherits UnauthorizedAppPage

<section class="login-page">
    <div class="login-panel">
        <div class="app-brand login-brand">
            <span class="app-brand-mark">D</span>
            <span>DotCast</span>
        </div>
        <h1>Sign in</h1>
        <Field>
            <FieldLabel>Username</FieldLabel>
            <FieldBody>
                <TextEdit @bind-Text="@Username" Placeholder="Enter your username" />
            </FieldBody>
        </Field>
        <Field>
            <FieldLabel>Password</FieldLabel>
            <FieldBody>
                <TextEdit @bind-Text="@Password" Role="TextRole.Password" Placeholder="Enter your password" />
            </FieldBody>
        </Field>
        <Field>
            <Check TValue="bool" Checked="@RememberMe">Remember Me</Check>
        </Field>
        <Button Color="Color.Primary" Clicked="@LoginAsync">Login</Button>
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="inline-status danger" role="alert">@Message</div>
        }
    </div>
</section>

@code {
    public string Username { get; set; } = null!;
    public string Password { get; set; } = null!;
    public bool RememberMe { get; set; }

    [Parameter]
    public string? Message { get; set; }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Message))
        {
            return;
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("Message", out var message))
        {
            Message = message.ToString();
        }
    }

    private async Task LoginAsync()
    {
        var loginModel = new LoginModel
        {
            Username = Username,
            Password = Password,
            RememberMe = RememberMe
        };

        await js.InvokeVoidAsync("loginUser", loginModel);
    }
}
