@page "/UserProfile"
@using DotCast.App.API
@inherits AppPage

<section class="account-page">
    <header class="page-hero compact">
        <p class="cinema-eyebrow">Account</p>
        <h1>@UserName</h1>
        <p>Manage your library code and sharing access.</p>
    </header>

    <main class="settings-grid">
        <section class="cinema-panel account-card">
            <div class="avatar-large">@UserName.FirstOrDefault().ToString().ToUpperInvariant()</div>
            <div>
                <h2>@UserName</h2>
                <p>Signed in to DotCast</p>
                <button class="danger-action" @onclick="() => NavigationManager.NavigateTo(LogoutEndpoint.Address, forceLoad: true)">Logout</button>
            </div>
        </section>

        <section class="cinema-panel">
            <p class="cinema-eyebrow">Library code</p>
            <h2>@LibraryName</h2>
            <p>Share this code with another DotCast user to grant library access.</p>
        </section>

        <section class="cinema-panel wide-panel">
            <div class="section-heading">
                <div>
                    <p class="cinema-eyebrow">Sharing</p>
                    <h2>Shared libraries</h2>
                </div>
            </div>

            <div class="share-form">
                <input id="share-input" type="text" @bind="NewShare" placeholder="Enter library code" />
                <button class="primary-action" @onclick="ShareAsync">Share</button>
            </div>
            @if (!string.IsNullOrWhiteSpace(ShareMessage))
            {
                <p class="inline-status">@ShareMessage</p>
            }

            @if (SharedLibrariesWith.Count == 0)
            {
                <p>No shared libraries yet.</p>
            }
            else
            {
                <div class="shared-list">
                    @foreach (var shareInfo in SharedLibrariesWith)
                    {
                        <article>
                            <div>
                                <strong>@shareInfo.UserName</strong>
                                <span>@shareInfo.LibraryCode</span>
                            </div>
                            <button class="danger-action" @onclick="() => UnShareAsync(shareInfo)">Unshare</button>
                        </article>
                    }
                </div>
            }
        </section>
    </main>
</section>
